rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /alerts/{alertId} {
      // Allow public read access to all alerts
      allow read: if true;
      
      // Allow create only for authenticated users (including anonymous)
      // and validate the data being written.
      allow create: if request.auth != null &&
                      request.resource.data.message is string &&
                      request.resource.data.message.size() >= 5 &&
                      request.resource.data.message.size() <= 140 &&
                      request.resource.data.type is string &&
                      request.resource.data.type in ['Traffic', 'Weather', 'Accident', 'Road Hazard', 'Collision'] &&
                      request.resource.data.timestamp == request.time;
                      
      // Disallow any client-side updates or deletes
      allow update, delete: if false;
    }
  }
}
