/**
 * @fileoverview Firestore Security Rules for the Alert System.
 *
 * Core Philosophy:
 * This ruleset provides public read access to alerts while restricting write access.
 * It assumes that all alerts are global and publicly accessible.
 *
 * Data Structure:
 * All alerts are stored in a top-level collection called `/alerts/{alertId}`.
 * Each alert document contains an `id`, a `message`, and a `timestamp`.
 *
 * Key Security Decisions:
 * - Public Read:  Alerts are intended to be publicly visible, so read access is open.
 * - Restricted Write: To prevent abuse, direct client-side writes (create, update, delete) are forbidden.
 *   Instead, a trusted backend environment (e.g., Cloud Functions) should handle alert creation and management.
 * - No User-Specific Data: The absence of user-related fields simplifies the rules and avoids complex authorization logic.
 * - Rate Limiting and Moderation: While not directly implemented in these rules, rate limiting and content moderation
 *   are essential considerations for a production system and should be handled in backend logic.
 *
 * Denormalization for Authorization:
 *   Not applicable, as there is no authorization requirement.
 *
 * Structural Segregation:
 *   Not applicable, as all alerts are stored in a single, public collection.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Grants public read access to alerts and restricts write access.
     * @path /alerts/{alertId}
     * @allow (get, list): Any user can read alerts.
     * @deny (create, update, delete): No client-side writes allowed.
     * @principle Allows public read access but restricts write access to a trusted environment.
     */
    match /alerts/{alertId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}