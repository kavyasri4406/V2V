rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Rules for the 'alerts' collection
    match /alerts/{alertId} {
      
      // ANYONE can read a single alert document.
      allow get: if true;

      // ONLY an authenticated user can create an alert.
      // Data must be valid.
      allow create: if request.auth != null &&
                      request.resource.data.message is string &&
                      request.resource.data.message.size() >= 5 &&
                      request.resource.data.message.size() <= 140 &&
                      request.resource.data.type is string &&
                      request.resource.data.type in ['Traffic', 'Weather', 'Accident', 'Road Hazard', 'Collision'] &&
                      request.resource.data.timestamp == request.time;

      // NO ONE can update or delete alerts from the client.
      allow update, delete: if false;

      // ANYONE can list the alerts collection to see the feed.
      allow list: if true;
    }
  }
}
