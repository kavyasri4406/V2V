rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /alerts/{document=**} {
      allow read: if true;
    }
    
    match /alerts/{alertId} {
      allow create: if request.auth != null;
    }
    
    match /sent-alerts/{alertId} {
      allow create: if request.auth != null;
    }
  }
}
